programa {
  funcao inicio() {
    real a,b,c,media
    escreva("Escreva a primeira nota do aluno: ")
    leia (a)
    escreva("Escreva a primeira nota do aluno: ")
    leia (b)
    escreva("Escreva a primeira nota do aluno: ")
    leia (c)

     a = a * 2
     b = b * 3
     c = c * 5

     media = ((a + b)+ c) / 10

     escreva("A media deste aluno é de: ", media)
  }
}
